// Prisma schema — defines all database tables.
// After editing this file, run: npx prisma migrate dev --name your-change-name
// This creates a migration SQL file AND updates the generated client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Shop ──────────────────────────────────────────────────────────────────
// One row per Shopify store that has installed your app.
// accessToken is the permanent token used to call Shopify's API on behalf of
// this store. Never expose it to the frontend.
model Shop {
  id          String   @id @default(uuid())
  domain      String   @unique  // e.g. "my-store.myshopify.com"
  accessToken String            // permanent OAuth token — keep secret
  scope       String            // scopes the merchant approved
  email       String?           // shop owner email (fetched from Shopify after install)
  name        String?           // shop name
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers     Customer[]
  billingPlans  BillingPlan[]
  subscriptions Subscription[]
}

// ─── Customer ──────────────────────────────────────────────────────────────
// One row per customer who has at least one subscription in this shop.
model Customer {
  id                String   @id @default(uuid())
  shopId            String
  shopifyCustomerId String?           // Shopify's numeric customer ID (as string)
  email             String
  firstName         String?
  lastName          String?
  phone             String?
  acceptsMarketing  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([shopId, email])   // same email can exist in different shops but not twice in one
  @@index([shopId])
  @@index([shopifyCustomerId])
}

// ─── BillingPlan ───────────────────────────────────────────────────────────
// Merchant-created subscription templates.
// Example: "Monthly Coffee Plan — every 30 days, 15% off, free shipping".
// Products aren't stored here — they're on the Subscription.
model BillingPlan {
  id            String      @id @default(uuid())
  shopId        String
  name          String                    // "Monthly Plan"
  description   String?                   // shown to customers
  intervalUnit  IntervalUnit              // WEEK | MONTH | YEAR
  intervalCount Int         @default(1)   // e.g. 2 = every 2 months
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Decimal     @default(0) @db.Decimal(10, 2)  // 10 = 10% or $10
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)   // display order in widget
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([shopId])
  @@index([shopId, isActive])
}

// ─── Subscription ──────────────────────────────────────────────────────────
// A customer enrolled in a billing plan.
// products is a JSON snapshot of what they're subscribing to — we snapshot it
// so if the Shopify product changes price, existing subscriptions aren't affected.
model Subscription {
  id              String             @id @default(uuid())
  shopId          String
  customerId      String
  billingPlanId   String
  status          SubscriptionStatus @default(ACTIVE)

  // Product snapshot: [{ variantId, title, price, quantity, imageUrl }]
  products        Json

  // Pricing at time of enrollment
  subtotal        Decimal   @db.Decimal(10, 2)  // before discount
  discountAmount  Decimal   @default(0) @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)  // what we actually charge

  // Billing schedule
  nextBillingDate DateTime
  lastBilledAt    DateTime?

  // Lifecycle timestamps
  trialEndsAt     DateTime?
  pausedAt        DateTime?
  pauseUntil      DateTime?   // auto-resume date (null = paused indefinitely)
  cancelledAt     DateTime?
  cancelReason    String?

  // Shopify address IDs — we store these to create orders via Shopify API
  shippingAddressId String?
  billingAddressId  String?

  // Stripe customer + payment method (for recurring billing)
  stripeCustomerId      String?
  stripePaymentMethodId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id])
  billingPlan BillingPlan @relation(fields: [billingPlanId], references: [id])
  billings    Billing[]

  @@index([shopId])
  @@index([customerId])
  @@index([status])
  @@index([nextBillingDate])  // used by the billing cron to find what's due
}

// ─── Billing ───────────────────────────────────────────────────────────────
// One row per charge attempt (succeeded or failed).
// We never delete these — they form the complete payment history.
model Billing {
  id             String        @id @default(uuid())
  subscriptionId String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD")
  status         BillingStatus @default(PENDING)

  // Stripe references
  stripePaymentIntentId String?
  stripeInvoiceId       String?

  // Shopify order created for this billing cycle
  shopifyOrderId String?

  // Failure handling
  failureReason  String?
  retryCount     Int       @default(0)
  nextRetryAt    DateTime?

  billedAt    DateTime  @default(now())
  succeededAt DateTime?
  refundedAt  DateTime?
  refundAmount Decimal?  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([billedAt])
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum BillingStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum IntervalUnit {
  WEEK
  MONTH
  YEAR
}

enum DiscountType {
  PERCENTAGE   // e.g. 10 = 10% off
  FIXED        // e.g. 5 = $5 off
}
